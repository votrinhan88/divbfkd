                'temperature':1,
            },
        }
    },
    'optim': {
        'num_epochs': 200,
        'opt_S': {
            'Class': torch.optim.SGD,
            'kwargs': {'lr':1e-1, 'momentum':0.9, 'weight_decay':5e-4},
        },
        'sch_S': {
            'Class': torch.optim.lr_scheduler.MultiStepLR,
            'kwargs': {'milestones':[100, 150], 'gamma':0.1},
        },
    }
},
